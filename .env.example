# Copy to `.env` or `.env.local` in the project root (same folder as package.json).
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# After changing env files, restart `pnpm dev`.

# MongoDB (Payload). Required for `pnpm dev` and production.
DATABASE_URL=

# Set automatically by the `pnpm dev` script. If you run `next dev` directly, add this
# to avoid MongoNotConnectedError when Payload’s HMR closes the DB during parallel RSC work.
# DISABLE_PAYLOAD_HMR=true

# Brevo — app.brevo.com → SMTP & API → API keys (transactional templates, etc.)
BREVO_API_KEY=
