# Copy to `.env` or `.env.local` in the project root (same folder as package.json).
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# After changing env files, restart `pnpm dev`.

# MongoDB (Payload). Required for `pnpm dev` and production.
DATABASE_URL=

# Payload
PAYLOAD_SECRET=
PAYLOAD_PUBLIC_SERVER_URL=

# Next.js (public, baked at build time)
NEXT_PUBLIC_SERVER_URL=

# Set automatically by the `pnpm dev` script. If you run `next dev` directly, add this
# to avoid MongoNotConnectedError when Payload’s HMR closes the DB during parallel RSC work.
# DISABLE_PAYLOAD_HMR=true

# Brevo — app.brevo.com → SMTP & API → API keys (transactional templates, etc.)
BREVO_API_KEY=

# Cloudflare R2 (S3-compatible storage for Payload Media)
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOKS_SIGNING_SECRET=

# Preview / draft access
PREVIEW_SECRET=
PREVIEW_PASSWORD=

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=

# DeepL (auto-translation hooks; optional locally)
DEEPL_API_KEY=

# Vercel (set automatically on deployments)
VERCEL=
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_BRANCH_URL=

# Feature flags / operational toggles (optional)
PAYLOAD_SKIP_GASTRONOMY_CONDITION=
PAYLOAD_SKIP_FERMENTATION_CONDITION=
PAYLOAD_SKIP_WORKSHOP_CONDITION=
